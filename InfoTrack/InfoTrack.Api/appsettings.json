{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "InfoTrack": "Information"
    }
  },
  "AllowedHosts": "*",
  "Scraping": {
    "BaseUrl": "https://www.solicitors.com",
    "EntryPath": "/conveyancing.html",
    "LocationPathTemplate": "/conveyancing+{location}.html",
    "UserAgent": "InfoTrack-Assessment/1.0",
    "RequestDelayMilliseconds": 250,
    "RequestTimeoutSeconds": 30,
    "Resilience": {
      "MaxRetryAttempts": 3,
      "RetryDelayMilliseconds": 500,
      "MaxRetryDelayMilliseconds": 5000,
      "CircuitBreakerFailureRatio": 50,
      "CircuitBreakerMinimumThroughput": 5,
      "CircuitBreakerBreakDurationSeconds": 30
    }
  },
  "Discovery": {
    "BaseUrl": "https://www.solicitors.com",
    "SitemapIndexPath": "/sitemap.xml",
    "ConveyancingSitemapPath": "/google-sitemap4.xml",
    "ConveyancingUrlSegment": "conveyancing+",
    "UserAgent": "InfoTrack-Assessment/1.0",
    "RequestTimeoutSeconds": 30,
    "Resilience": {
      "MaxRetryAttempts": 3,
      "RetryDelayMilliseconds": 500,
      "MaxRetryDelayMilliseconds": 5000,
      "CircuitBreakerFailureRatio": 50,
      "CircuitBreakerMinimumThroughput": 5,
      "CircuitBreakerBreakDurationSeconds": 30,
      "RateLimiterPermitLimit": 10,
      "RateLimiterQueueLimit": 20,
      "BulkheadMaxParallelization": 2,
      "BulkheadMaxQueuedActions": 10
    }
  },
  "Operations": {
    "ChannelCapacity": 100
  },
  "Mcp": {
    "Enabled": true,
    "ApiKey": "dev-mcp-api-key-change-me",
    "ServerName": "InfoTrack Solicitor Intelligence",
    "ServerVersion": "1.0",
    "RequireHttps": false,
    "EnableAssistant": true
  },
  "LocalLlm": {
    "Enabled": true,
    "BaseUrl": "http://localhost:1234",
    "Model": "qwen2.5-3b-instruct",
    "MaxToolRounds": 5,
    "MaxToolResultCharacters": 12000,
    "RequestTimeoutSeconds": 120
  }
}
