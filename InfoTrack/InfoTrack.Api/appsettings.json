{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "InfoTrack": "Information"
    }
  },
  "AllowedHosts": "*",
  "Scraping": {
    "BaseUrl": "https://www.solicitors.com",
    "EntryPath": "/conveyancing.html",
    "LocationPathTemplate": "/conveyancing+{location}.html",
    "UserAgent": "InfoTrack-Assessment/1.0",
    "RequestDelayMilliseconds": 250
  },
  "Discovery": {
    "BaseUrl": "https://www.solicitors.com",
    "SitemapIndexPath": "/sitemap.xml",
    "ConveyancingSitemapPath": "/google-sitemap4.xml",
    "ConveyancingUrlSegment": "conveyancing+",
    "UserAgent": "InfoTrack-Assessment/1.0",
    "RequestTimeoutSeconds": 30
  }
}
